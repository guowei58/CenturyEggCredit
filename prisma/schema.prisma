  ticker                             String
  companyName                        String?   @map("company_name") @db.Text
  /** Registrant / parent legal name as filed */
  publicRegistrantName               String?   @map("public_registrant_name") @db.Text
  stateOfIncorporation               String?   @map("state_of_incorporation")
  hqAddress                          String?   @map("hq_address") @db.Text
