# Copy to .env.local and fill in. Restart dev server after changes.

# EdgarTools Python bridge (tab hidden from nav for now; API routes still proxy here if used).
# Run: cd edgar-bridge && pip install -r requirements.txt && set EDGAR_IDENTITY=Your Name you@example.com && uvicorn main:app --host 127.0.0.1 --port 8765
# Development default if unset: http://127.0.0.1:8765. Production: set explicitly (e.g. private service URL).
# EDGAR_TOOLS_BRIDGE_URL=http://127.0.0.1:8765

# AI Credit Memo tab — local ticker research folders (server-only). Subfolders under this path are matched to tickers.
# Example (Windows): RESEARCH_ROOT_DIR=C:\Users\you\Documents\CenturyEggResearch
# If unset, only data/saved-tickers/{TICKER}/ is used as a resolve candidate.
RESEARCH_ROOT_DIR=
CREDIT_MEMO_MAX_CONTEXT_CHARS=50000000
CREDIT_MEMO_MAX_OUTPUT_TOKENS=16000
CREDIT_MEMO_MAX_FILES=400
CREDIT_MEMO_MAX_FILE_BYTES=18874368
# Optional: model overrides for memo generation (falls back to ANTHROPIC_MODEL / OPENAI_MODEL)
# ANTHROPIC_CREDIT_MEMO_MODEL=
# OPENAI_CREDIT_MEMO_MODEL=

# Local Ollama (AI Chat, Covenants, credit memo/deck, overview, presentations). See docs/ollama-setup.md
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# Optional: AI_DEFAULT_PROVIDER=ollama
# Optional: OLLAMA_TEMPERATURE=0.7
# Optional: OLLAMA_COMMITTEE_MODEL=  OLLAMA_COVENANT_MODEL=  OLLAMA_CREDIT_MEMO_MODEL=  OLLAMA_OVERVIEW_MODEL=  OLLAMA_PRESENTATIONS_MODEL=

# Google Gemini (OpenAI-compatible API; AI Chat, Covenants, credit memo/deck, overview, presentations). Server-only.
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# Optional: GEMINI_MODEL=gemini-2.5-flash-lite
# Optional: AI_DEFAULT_PROVIDER=gemini
# Optional: GEMINI_COMMITTEE_MODEL=  GEMINI_COVENANT_MODEL=  GEMINI_CREDIT_MEMO_MODEL=  GEMINI_OVERVIEW_MODEL=  GEMINI_PRESENTATIONS_MODEL=

# AI Credit Memo template (DOCX) is managed in-app:
# - Upload on the AI Credit Memo tab → Template panel
# - Stored at data/credit-memo/template.docx and parsed headings at data/credit-memo/template.json


# Financial Modeling Prep — Historical Financial Statements tab (use Stable API; key in dashboard)
# https://site.financialmodelingprep.com/developer/docs/stable
FMP_API_KEY=

# USPTO Open Data Portal — Documents → Trademark IP Filings (patent application search)
# https://data.uspto.gov/apis/getting-started
USPTO_API_KEY=

# Optional: PatentsView — granted patents / assignee enrichment (same tab)
# https://patentsview.org/apis/purpose
USPTO_PATENTSVIEW_API_KEY=

# Optional: TSDR — trademark status lookup by serial number in-app
# https://developer.uspto.gov
USPTO_TSDR_API_KEY=

# Ratings / Research Links tab — official Fitch, Moody's, S&P URL discovery (Google Programmable Search OR SerpApi)
# https://developers.google.com/custom-search/v1/introduction
# https://serpapi.com/
SEARCH_PROVIDER=google
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
SERPAPI_API_KEY=

# Reddit Research tab — official OAuth2 (script app) + oauth.reddit.com search API (server-only secrets)
# https://github.com/reddit-archive/reddit/wiki/OAuth2
# Create app: https://www.reddit.com/prefs/apps — type "script"; note client id & secret.
# Password grant may be unavailable for newly registered apps per Reddit policy; use an eligible developer account.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Descriptive UA (include contact/repo); required by Reddit.
REDDIT_USER_AGENT=CenturyEggCredit/1.0 (reddit research; by YOUR_CONTACT)
# Optional tuning
REDDIT_MAX_QUERY_VARIANTS=12
REDDIT_MAX_SUBREDDITS_SEARCHED=12
REDDIT_MAX_PAGES_PER_QUERY=2
REDDIT_LIMIT_PER_REQUEST=25
REDDIT_MAX_POSTS_RETURNED=150
REDDIT_MAX_REQUESTS_PER_SEARCH=80
REDDIT_TIMEOUT_MS=15000
REDDIT_CACHE_TTL_MS=1800000
# Comma-separated lowercase names (override default finance subs)
# REDDIT_DEFAULT_SUBREDDITS=stocks,investing,wallstreetbets,securityanalysis

# Substack Search tab (discovery + RSS index)
SUBSTACK_DISCOVERY_ENABLED=true
SUBSTACK_RSS_INGEST_ENABLED=true
SUBSTACK_MAX_DISCOVERY_RESULTS=50
SUBSTACK_MAX_PUBLICATIONS_PER_RUN=20
SUBSTACK_MAX_POSTS_PER_FEED=100
SUBSTACK_REQUEST_TIMEOUT_MS=12000

# The Cap Stack Rumor Mill (public research discovery)
RESEARCH_FINDER_MAX_QUERIES_PER_PROVIDER=10
RESEARCH_FINDER_MAX_CANDIDATES_PER_PROVIDER=40
RESEARCH_FINDER_MAX_EXTRACTED_PER_PROVIDER=20
RESEARCH_FINDER_TIMEOUT_MS=10000
RESEARCH_FINDER_CACHE_TTL_MS=21600000

# X / Twitter Sentiment tab (official X API v2)
X_BEARER_TOKEN=
X_RECENT_SEARCH_ENABLED=true
X_FULL_ARCHIVE_ENABLED=false
X_FILTERED_STREAM_ENABLED=false
X_DEFAULT_RESULT_LIMIT=100
X_INCLUDE_RETWEETS=false
X_DEFAULT_LANGUAGE=en
X_REQUEST_TIMEOUT_MS=10000
X_COUNTS_ENABLED=true

# Broker Research Reports tab — discovery index via Google CSE JSON API or SerpApi (same SEARCH_PROVIDER / keys as above).
# Optional tuning:
BROKER_RESEARCH_MAX_QUERIES_PER_BROKER=10
BROKER_RESEARCH_GLOBAL_MAX_RESULTS=200
BROKER_RESEARCH_HITS_PER_QUERY=8
# Per-broker enable flags (suffix matches src/lib/brokerResearch/config.ts → BROKER_ID_TO_ENV_SUFFIX):
# BROKER_RESEARCH_JPM_ENABLED=true
# BROKER_RESEARCH_GOLDMAN_ENABLED=true
# BROKER_RESEARCH_MORGAN_STANLEY_ENABLED=true
# BROKER_RESEARCH_UBS_ENABLED=true
# BROKER_RESEARCH_BOFA_ENABLED=true
# … (all 25 production brokers; omit to use each broker’s default)

# News aggregation (News & Events tab — live feed). Keys are server-side only (API route).
MARKETAUX_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
# NewsAPI (everything + domains + searchIn=title; see src/lib/news/newsApiDomains.ts)
NEWSAPI_KEY=

# Optional mock provider for automated tests: set to __mock__ and register MOCK in test registrations.
MOCK_NEWS_API_KEY=

NEWS_PROVIDER_MARKETAUX_ENABLED=true
NEWS_PROVIDER_ALPHA_VANTAGE_ENABLED=true
NEWS_PROVIDER_FINNHUB_ENABLED=true
NEWS_PROVIDER_NEWSAPI_ENABLED=true

NEWS_PROVIDER_MARKETAUX_PRIORITY=1
NEWS_PROVIDER_ALPHA_VANTAGE_PRIORITY=2
NEWS_PROVIDER_FINNHUB_PRIORITY=3
NEWS_PROVIDER_NEWSAPI_PRIORITY=4

NEWS_PROVIDER_MARKETAUX_TIMEOUT_MS=8000
NEWS_PROVIDER_ALPHA_VANTAGE_TIMEOUT_MS=8000
NEWS_PROVIDER_FINNHUB_TIMEOUT_MS=8000
NEWS_PROVIDER_NEWSAPI_TIMEOUT_MS=8000

NEWS_PROVIDER_MARKETAUX_MAX_RESULTS=50
NEWS_PROVIDER_ALPHA_VANTAGE_MAX_RESULTS=50
NEWS_PROVIDER_FINNHUB_MAX_RESULTS=50
NEWS_PROVIDER_NEWSAPI_MAX_RESULTS=100

# Environmental Risk tab — SEC + EPA (ECHO + Envirofacts FRS). Server-only; no API key required for EPA public services.
# Optional: custom User-Agent strings (include contact email for SEC politeness).
# SEC_EDGAR_USER_AGENT=YourApp/1.0 (you@example.com)
# EPA_HTTP_USER_AGENT=YourApp/1.0 (you@example.com)
ENV_RISK_CACHE_TTL_MS=86400000
ENV_RISK_MAX_FILING_FETCHES=12
ENV_RISK_ECHO_PAGE_SIZE=25
ENV_RISK_MAX_FRS_QUERIES=6
ENV_RISK_MAX_ECHO_QUERIES=3
ENV_RISK_REQUEST_TIMEOUT_MS=45000
# Set to false to disable individual connectors
ENV_RISK_ENABLE_ECHO=true
ENV_RISK_ENABLE_ENVIROFACTS=true
ENV_RISK_ENABLE_RCRA=true
# State agency connectors (v1 stub unless true)
ENV_RISK_ENABLE_STATE_CONNECTORS=false
# Optional: DATA_GOV_API_KEY=  (not required for ECHO / efservice URLs used in v1)
